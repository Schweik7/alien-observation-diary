{
  "name": "earthling-diary-online",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "《地球人观察日记》在线多人版 · 实时房间猜测游戏",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"node server/index.js\" \"vite\"",
    "dev:server": "node server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^6.0.7"
  }
}
